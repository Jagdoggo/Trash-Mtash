[node name="Small Info" type="Label" parent="Educational/VBoxContainer" unique_id=1208253243]
custom_maximum_size = Vector2(350, -1)
layout_mode = 2
theme_override_font_sizes/font_size = 9
text = "Toggle build mode: B
Toggle driving: V
Cycle selected part: E and Q
Move part place position: W, A, S, and D
Place part: F
Remove Part: Y
Set part parent: U
Reset part parent: N
Change servo group: G and H
Pickup trash: Y
Rotate part: All arrows + Comma + Dot
Toggle Magnet: R
Activate propeller: Space
Rotate servo: [ and ]
Rotate elevator servo: w and s
Rotate aileron servo: a and d
Swap driving direction: P
Swap steering Direction: L"
horizontal_alignment = 1
vertical_alignment = 1
autowrap_mode = 3

