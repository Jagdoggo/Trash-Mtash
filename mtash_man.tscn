[node name="Educational" type="Control" parent="." unique_id=238147524]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("2_egqov")
popups = Array[String](["Did you that trash builup is a real problem", "Did you know that about 4 million tons of trash are thrown away daily", "Did you know that less than 10% of landfill trash makes it to a recycling facility", "Did you know that most of landfill trash is organic/food waste", "Did you know that the other main source of landfill trash is plastic", "Did you know that all the power sources in this game are renewable", "Not all of your vehicle ideas have to be only in game, some people have created real life trash collecting vehicles"])
tutorial_text = Array[String](["Press J to advance tutorial(not the button your told to press)", "Press ESC to acess the menu and press help to find more info", "To save the game press the save and quit button on the menu(if on web, do NOT close the tab or reload without saving)", "Press B to enter build mode", "W, A, S, D, Shift, Control moves the position the block will place", "E and Q change the current block your placing", "F places a block", "Arrow keys rotate a block", "Comma and period also rotate a block", "Make a 3 long frame out of blocks", "Add wheel(steer) to the front of your vehicle", "Add normal wheels to the back of your vehicle", "Add a seat somewhere on the vehicle", "Add solar panels to your vehicle to make net power be positive", "Press B to exit build mode and V to drive", "You may need to press P or L to reverse driving and steering direction", "Go back into build mode and build a collection area at the front of your vehicle to collect trash and recycle it", "Drive your vehicle to collect some trash and recycle it", "There is diffrent trash types that give you diffrent blocks when taken to recycling centre", "If you take enough trash from a chunk, it will be cleared(this is the primary goal)", "Now you can upgrade your vehicle however you like", "Remember  there is the help button when you need it"])
cleared_text = "Well done clearing the chunk"

